{
  "name": "@code-charter/vscode",
  "displayName": "Code Charter",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.87.0"
  },
  "publisher": "crjfisher",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "code-charter-vscode.generateDiagram",
        "title": "Code Charter: Visualize Code Trees"
      },
      {
        "command": "code-charter-vscode.installDrift",
        "title": "Code Charter: Install Drift Sync Into Workspace"
      }
    ],
    "configuration": {
      "title": "Code Charter",
      "properties": {
        "code-charter-vscode.devMode": {
          "order": 1,
          "type": "boolean",
          "default": false,
          "description": "Enable development mode to load UI from dev server"
        },
        "code-charter-vscode.devServerUrl": {
          "order": 2,
          "type": "string",
          "default": "http://localhost:3000",
          "description": "URL of the UI development server"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "tsc -p ./",
    "compile": "tsc -p ./",
    "dev": "tsc -watch -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf out"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^18.19.26",
    "@types/vscode": "^1.87.0",
"jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@ariadnejs/core": "^0.8.0",
    "@ariadnejs/types": "^0.8.0",
    "@code-charter/core": "^0.0.1",
    "@code-charter/drift": "^0.0.1",
    "@code-charter/types": "^0.0.1",
    "@code-charter/ui": "^0.0.1",
    "@vscode/python-extension": "^1.0.5"
  }
}
